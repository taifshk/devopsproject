pipeline {
    agent any

    stages {
        stage('Docker Build & Deploy') {
            steps {
                script {
                    // Build image from the current root
                    sh "docker build -t devops-burger-app ."
                    
                    // Cleanup old container
                    sh "docker rm -f devops-burger-container || true"
                    
                    // Run container on Port 5000
                    sh "docker run -d -p 5000:5000 --name devops-burger-container devops-burger-app"
                }
            }
        }

        stage('XAMPP Deployment') {
            steps {
                script {
                    // Since files are in the root (A-2), we copy *.* from root
                    // We exclude the .git folder and the Jenkinsfile itself to keep it clean
                    bat """
                    if not exist "C:\\xampp\\htdocs\\devopsproject" mkdir "C:\\xampp\\htdocs\\devopsproject"
                    xcopy /y /s /i "*.*" "C:\\xampp\\htdocs\\devopsproject"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "Deployment Successful!"
            echo "Docker: http://localhost:5000"
            echo "XAMPP: http://localhost/devopsproject"
        }
    }
}