pipeline {
    agent any

    environment {
        // Docker Configuration
        DOCKER_IMAGE = "spicy-burger-app"
        DOCKER_TAG = "${env.BUILD_ID}"
        
        // XAMPP Configuration (Adjust this path if your XAMPP is on a different drive)
        XAMPP_HTDOCS = "C:/xampp/htdocs/spicy-burger"
    }

    stages {
        stage('Checkout') {
            steps {
                // Pulls the latest code from your GitHub repository
                checkout scm
            }
        }

        stage('Docker Deployment') {
            steps {
                script {
                    echo "--- STARTING DOCKER BUILD & DEPLOY ---"
                    // 1. Build the image from your Dockerfile
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    
                    // 2. Kill the old container if it exists so there is no port conflict
                    sh "docker rm -f spicy-burger-container || true"
                    
                    // 3. Run the new container on Port 5000
                    sh "docker run -d -p 5000:5000 --name spicy-burger-container ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    echo "Docker container is live on Port 5000"
                }
            }
        }

        stage('XAMPP Deployment') {
            steps {
                script {
                    echo "--- STARTING XAMPP DEPLOY ---"
                    // Use 'bat' for Windows commands to copy files to htdocs
                    // This creates the folder if missing and copies all frontend files
                    bat """
                    if not exist "${XAMPP_HTDOCS}" mkdir "${XAMPP_HTDOCS}"
                    xcopy /s /y "frontend\\*" "${XAMPP_HTDOCS}"
                    """
                    echo "Files copied to XAMPP htdocs"
                }
            }
        }
    }

    post {
        success {
            echo "SUCCESS: Your Burger Site is updated everywhere!"
            echo "View via Docker: http://localhost:5000"
            echo "View via XAMPP: http://localhost/devopsproject"
        }
        failure {
            echo "FAILURE: The deployment failed. Check the 'Console Output' in Jenkins."
        }
    }
}