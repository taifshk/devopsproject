environment {
    XAMPP_DIR = "C:\\xampp\\htdocs\\devopsproject"
}

stages {
    stage('Deploy') {
        steps {
            script {
                bat """
                @echo off
                if exist "${XAMPP_DIR}" rd /s /q "${XAMPP_DIR}"
                mkdir "${XAMPP_DIR}"
                xcopy /y /s /e /i "*" "${XAMPP_DIR}\\"
                """
            }
        }
    }
}

post {
    success {
        echo "Deployment successful: http://localhost/devopsproject"
    }
}