pipeline {
agent any

stages {
    stage('Deploy to XAMPP') {
        steps {
            script {
                // This removes the old folder to fix the "Index of" issue
                bat 'if exist "C:\\xampp\\htdocs\\devopsproject" rd /s /q "C:\\xampp\\htdocs\\devopsproject"'
                
                // This creates the folder fresh
                bat 'mkdir "C:\\xampp\\htdocs\\devopsproject"'

                // This copies everything from your project to XAMPP
                bat 'xcopy /Y /S /E /I "*" "C:\\xampp\\htdocs\\devopsproject\\"'
                
                // This proves the files are there in the Jenkins logs
                bat 'dir "C:\\xampp\\htdocs\\devopsproject"'
            }
        }
    }
}

post {
    success {
        echo "SUCCESS: Check http://localhost/devopsproject"
    }
}