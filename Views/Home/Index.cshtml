@{
    ViewData["Title"] = "DevOps Control Center";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-primary text-white rounded-3 shadow">
        <div>
            <h1 class="display-5 fw-bold">devopsproject</h1>
            <p class="lead mb-0">WebOps Architecture & CI/CD Management</p>
        </div>
        <div class="text-end">
            <span class="badge bg-success p-2">System: Healthy</span>
            <div class="mt-2 small">Node: Linux-Container-01</div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Build Status</h6>
                    <h3 class="fw-bold text-success">Passing</h3>
                    <div class="progress mt-2" style="height: 5px;">
                        <div class="progress-bar bg-success" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Deployments</h6>
                    <h3 class="fw-bold">14 / Day</h3>
                    <p class="text-muted mb-0 small">+2 from yesterday</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-info border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Lead Time</h6>
                    <h3 class="fw-bold">8.4 min</h3>
                    <p class="text-muted mb-0 small">Optimized via CI/CD</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-danger border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Error Rate</h6>
                    <h3 class="fw-bold">0.02%</h3>
                    <p class="text-muted mb-0 small">Near zero downtime</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Recent Pipeline Activity</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <strong>Commit #4209</strong> - Update index UI
                            </div>
                            <span class="text-muted small">2 mins ago</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <strong>Build #892</strong> - Merge main branch
                            </div>
                            <span class="text-muted small">1 hour ago</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card bg-dark text-white shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-4">Resource Pool Log</h5>
                    <code class="text-info small">
                        > Initializing Linux OS...<br />
                        > Pulling Docker Image...<br />
                        > Running npm build...<br />
                        > Deploying to Staging...<br />
                        > SUCCESS: Site Live
                    </code>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">